
{
  "entities": {
    "Package": {
      "title": "Package",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "basePrice": { "type": "number" },
        "durationDays": { "type": "number" },
        "isActive": { "type": "boolean" }
      }
    },
    "Announcement": {
      "title": "Announcement",
      "type": "object",
      "description": "Admin-posted broadcasts for all travelers.",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "priority": { "type": "string", "enum": ["low", "medium", "high"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "content", "createdAt"]
    },
    "UserDocument": {
      "title": "UserDocument",
      "type": "object",
      "description": "Confidential files assigned to specific users.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "fileUrl": { "type": "string" },
        "type": { "type": "string", "enum": ["Certificate", "Itinerary", "Invoice", "Other"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "title", "fileUrl"]
    },
    "SupportMessage": {
      "title": "SupportMessage",
      "type": "object",
      "description": "Messages in a private chat thread between user and support.",
      "properties": {
        "id": { "type": "string" },
        "threadId": { "type": "string" },
        "senderId": { "type": "string" },
        "text": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "firestore": {
    "structure": [
      {
        "path": "/announcements",
        "definition": {
          "entityName": "Announcement",
          "description": "Public broadcasts for logged-in travelers."
        }
      },
      {
        "path": "/user_documents",
        "definition": {
          "entityName": "UserDocument",
          "description": "Private documents restricted by userId."
        }
      },
      {
        "path": "/support_threads/{userId}/messages",
        "definition": {
          "entityName": "SupportMessage",
          "description": "Private communication history between a traveler and admin."
        }
      }
    ]
  }
}
