
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // USERS COLLECTION
    match /users/{userId} {
      allow read, update: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null;
      allow delete: if request.auth != null && request.auth.uid == userId;
      
      // Admin override
      allow read, write: if request.auth != null && request.auth.token.role == "admin";
    }

    // BOOKINGS COLLECTION
    match /bookings/{bookingId} {
      allow create: if request.auth != null && request.resource.data.userID == request.auth.uid;
      allow read, update, delete: if request.auth != null && resource.data.userID == request.auth.uid;

      // Admin override
      allow read, write: if request.auth != null && request.auth.token.role == "admin";
    }

    // CUSTOM BOOKINGS (Combo Builder)
    match /customBookings/{bookingId} {
      allow create: if true;
      allow read: if request.auth != null && (resource.data.userId == request.auth.uid || request.auth.token.role == "admin");
    }

    // PAYMENTS COLLECTION
    match /payments/{paymentId} {
      allow create, update, delete: if request.auth != null && request.auth.token.role == "admin";
      allow read: if request.auth != null && resource.data.userID == request.auth.uid;
      allow read, write: if request.auth != null && request.auth.token.role == "admin";
    }

    // DESTINATIONS, PACKAGES, ADDONS
    match /destinations/{destId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.role == "admin";
    }

    match /packages/{packageId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.role == "admin";
    }

    match /addons/{addonId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.role == "admin";
    }

    // BLOG POSTS & GALLERY
    match /posts/{postId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /gallery/{imageId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // IDEAS & VOTES
    match /ideas/{ideaId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // CHATS
    match /chats/{chatId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // EMAIL TEMPLATES
    match /emails/{templateId} {
      allow read: if request.auth != null && request.auth.token.role == "admin";
      allow write: if request.auth != null && request.auth.token.role == "admin";
    }
  }
}
